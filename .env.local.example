# Copy this file to .env.local and paste your real Supabase values.
# Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Patient entry uses unique doctor codes (/d/CODE), not a default clinic slug.

# Never put service_role key here or in any frontend env file.
